# ─── Backend API ──────────────────────────────────────────────────────────────
# Use your machine's LAN IP (NOT localhost) when testing on a physical device
# Find it with: ip addr show | grep "inet " on Linux, or ifconfig on macOS
EXPO_PUBLIC_API_URL=http://192.168.x.x:3000

# ─── Firebase (same project as the web app) ───────────────────────────────────
# Get from: Firebase Console → Project Settings → General → Your apps → Web app
# These are the same values as NEXT_PUBLIC_FIREBASE_* in the web app's .env
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# ─── Stripe (publishable key only — secret key stays on the server) ───────────
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
